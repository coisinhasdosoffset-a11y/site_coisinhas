<%- include('partials/header', { page: 'outros-crafts' }) %>

<section class="other-crafts-page">
  <div class="other-crafts-hero glass">
    <div class="other-crafts-hero-text">
      <span class="other-crafts-badge">Módulo • Outros Crafts</span>
      <h1>Outros Crafts</h1>
      <p>
        Calcula processos, vendas de minas e pesca sem misturar tudo. Escolhe uma área,
        ajusta o tipo de preço e guarda o teu cálculo.
      </p>
    </div>

    <div class="other-crafts-menu glass">
      <strong>Áreas disponíveis</strong>

      <button type="button" class="other-craft-tab active" data-craft="minas">
        <span class="craft-tab-icon">⛏</span>
        <span>
          <b>Minas</b>
          <small>Processos e vendas</small>
        </span>
      </button>

      <button type="button" class="other-craft-tab" data-craft="pesca">
        <span class="craft-tab-icon">🎣</span>
        <span>
          <b>Pesca</b>
          <small>Peixes, ilegal e materiais</small>
        </span>
      </button>

      <button type="button" class="other-craft-tab craft-tab-disabled" disabled>
        <span class="craft-tab-icon">＋</span>
        <span>
          <b>Nova área</b>
          <small>Preparado para adicionares depois</small>
        </span>
      </button>
    </div>
  </div>

  <div class="other-crafts-workspace">
    <div class="craft-section glass active" data-craft-section="minas">
      <div class="craft-section-head">
        <div>
          <span class="craft-section-tag">Secção 1</span>
          <h2>Minas</h2>
          <p>Na esquerda colocas as quantidades e adicionas vendas. Na direita vês todos os resultados.</p>
        </div>

        <div class="other-filter-box">
          <label for="minasMode">Tipo</label>
          <select id="minasMode" data-mode-select="minas">
            <option value="civil">Civil / Sem equipa</option>
            <option value="equipa">Com equipa</option>
            <option value="parceria">Parceria</option>
          </select>
        </div>
      </div>

      <div class="minas-split-layout">
        <div class="minas-input-column">
          <div class="process-panel glass">
            <div class="mini-panel-head">
              <span class="mini-panel-badge">Processos</span>
              <h3>Calculadora de processos</h3>
              <p>Coloca a quantidade processada de cada recurso.</p>
            </div>

            <div class="process-grid" id="processInputs"></div>
          </div>

          <div class="sale-panel glass minas-sale-input-panel">
            <div class="mini-panel-head">
              <span class="mini-panel-badge">Vendas</span>
              <h3>Calculadora de vendas</h3>
              <p>Adiciona os itens que queres vender.</p>
            </div>

            <div class="craft-list" id="minasSaleList"></div>
          </div>
        </div>

        <div class="minas-result-column">
          <div class="process-results-panel glass">
            <div class="mini-panel-head">
              <span class="mini-panel-badge">Resultado processos</span>
              <h3>Resultado dos processos</h3>
              <p>Quantidade final depois da percentagem retirada e valor da fatura.</p>
            </div>

            <div class="process-result-head">
              <strong>Tipo selecionado</strong>
              <span id="processModeLabel">Civil / Sem equipa</span>
            </div>

            <div class="process-result-list" id="processResults"></div>

            <div class="summary-row process-total-row">
              <span>Total fatura</span>
              <strong id="processTotal">0€</strong>
            </div>
          </div>

          <div class="sale-panel glass minas-sale-result-panel">
            <div class="mini-panel-head">
              <span class="mini-panel-badge">Resultado vendas</span>
              <h3>Resultado da venda</h3>
              <p>Quantidades, valores por unidade e total da venda.</p>
            </div>

            <div class="other-summary-list" id="minasSaleSummary">
              <div class="empty-calc">
                <span class="empty-dot"></span>
                Ainda não adicionaste nenhum item.
              </div>
            </div>

            <div class="other-total-box">
              <div class="summary-row">
                <span>Total venda</span>
                <strong id="minasSaleTotal">0€</strong>
              </div>
            </div>

            <div class="other-summary-actions">
              <button type="button" class="btn btn-primary" data-save="minas">Guardar</button>
              <button type="button" class="btn btn-secondary" data-clear="minas">Limpar</button>
            </div>

            <div class="save-message" id="minasSaveMessage"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="craft-section glass" data-craft-section="pesca">
      <div class="craft-section-head">
        <div>
          <span class="craft-section-tag">Secção 2</span>
          <h2>Pesca</h2>
          <p>Filtra por categoria, adiciona itens e calcula o total para Civil ou Parceria.</p>
        </div>

        <div class="other-filter-stack">
          <div class="other-filter-box">
            <label for="pescaMode">Tipo</label>
            <select id="pescaMode" data-mode-select="pesca">
              <option value="civil">Civil</option>
              <option value="parceria">Parceria</option>
            </select>
          </div>

          <div class="other-filter-box">
            <label for="pescaCategory">Categoria</label>
            <select id="pescaCategory">
              <option value="todos">Todos</option>
              <option value="Peixe">Peixe</option>
              <option value="Peixe Ilegal">Peixe Ilegal</option>
              <option value="Item Ilegal">Item Ilegal</option>
              <option value="Material">Material</option>
            </select>
          </div>
        </div>
      </div>

      <div class="other-crafts-two-panels">
        <div class="sale-panel glass full-sale-panel">
          <div class="mini-panel-head">
            <span class="mini-panel-badge">Catálogo</span>
            <h3>Itens de Pesca</h3>
            <p>Escolhe os itens a adicionar ao cálculo.</p>
          </div>

          <div class="craft-list" id="pescaSaleList"></div>
        </div>

        <div class="sale-panel glass">
          <div class="mini-panel-head">
            <span class="mini-panel-badge">Resumo</span>
            <h3>Cálculo da Pesca</h3>
            <p>Quantidades, totais e guardar cálculo.</p>
          </div>

          <div class="other-summary-list" id="pescaSaleSummary">
            <div class="empty-calc">
              <span class="empty-dot"></span>
              Ainda não adicionaste nenhum item.
            </div>
          </div>

          <div class="other-total-box">
            <div class="summary-row">
              <span>Total pesca</span>
              <strong id="pescaSaleTotal">0€</strong>
            </div>
          </div>

          <div class="other-summary-actions">
            <button type="button" class="btn btn-primary" data-save="pesca">Guardar</button>
            <button type="button" class="btn btn-secondary" data-clear="pesca">Limpar</button>
          </div>

          <div class="save-message" id="pescaSaveMessage"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const PROCESS_RESOURCES = [
    {
      key: 'minerio',
      name: 'Minério/Pedra Dura',
      output: 'Enxofre e Níquel',
      invoice: { civil: 0, equipa: 0, parceria: 0 },
      percent: { civil: 35, equipa: 35, parceria: 35 }
    },
    {
      key: 'cobre',
      name: 'Cobre',
      output: 'Cobre',
      invoice: { civil: 200, equipa: 160, parceria: 40 },
      percent: { civil: 20, equipa: 20, parceria: 20 }
    },
    {
      key: 'prata',
      name: 'Prata',
      output: 'Prata',
      invoice: { civil: 140, equipa: 112, parceria: 28 },
      percent: { civil: 30, equipa: 30, parceria: 30 }
    },
    {
      key: 'areia',
      name: 'Areia',
      output: 'Vidro',
      invoice: { civil: 45, equipa: 36, parceria: 9 },
      percent: { civil: 55, equipa: 55, parceria: 55 }
    }
  ];

  const SALE_DATA = {
    minas: [
      { name: 'Pack safiras', type: 'Minas', civil: 21600, parceria: 23040, equipa: 21600 },
      { name: 'Diamantes', type: 'Minas', civil: 13500, parceria: 14400, equipa: 13500 },
      { name: 'Barras ouro', type: 'Minas', civil: 11250, parceria: 12000, equipa: 11250 },
      { name: 'Anel diamantes', type: 'Minas', civil: 3750, parceria: 4000, equipa: 3750 },
      { name: 'Relógio', type: 'Minas', civil: 2250, parceria: 2400, equipa: 2250 },
      { name: 'Corrente ouro 10k', type: 'Minas', civil: 1500, parceria: 1600, equipa: 1500 },
      { name: 'Correntes', type: 'Minas', civil: 750, parceria: 800, equipa: 750 },
      { name: 'Safira', type: 'Minas', civil: 1080, parceria: 1152, equipa: 1080 },
      { name: 'Pepita', type: 'Minas', civil: 300, parceria: 320, equipa: 300 }
    ],
    pesca: [
      { group: 'Peixe' },
      { name: 'Robalo Pequeno', type: 'Peixe', civil: 2880, parceria: 3168 },
      { name: 'Garoupa Pequena', type: 'Peixe', civil: 3520, parceria: 3872 },
      { name: 'Atum Pequeno', type: 'Peixe', civil: 9600, parceria: 10560 },
      { name: 'Robalo Grande', type: 'Peixe', civil: 4800, parceria: 5280 },
      { name: 'Garupa Grande', type: 'Peixe', civil: 7520, parceria: 8272 },
      { name: 'Atum Grande', type: 'Peixe', civil: 24000, parceria: 26400 },

      { group: 'Peixe Ilegal' },
      { name: 'Raia', type: 'Peixe Ilegal', civil: 3510, parceria: 4037 },
      { name: 'Polvo', type: 'Peixe Ilegal', civil: 4550, parceria: 5233 },
      { name: 'Tubarão Branco', type: 'Peixe Ilegal', civil: 9100, parceria: 10465 },
      { name: 'Tubarão Martelo', type: 'Peixe Ilegal', civil: 10400, parceria: 11960 },
      { name: 'Orca', type: 'Peixe Ilegal', civil: 65000, parceria: 74750 },
      { name: 'Baleia', type: 'Peixe Ilegal', civil: 650000, parceria: 747500 },

      { group: 'Item Ilegal' },
      { name: 'Pacote Ilegal', type: 'Item Ilegal', civil: 5860, parceria: 5860 },
      { name: 'Diário De Bordo', type: 'Item Ilegal', civil: 7800, parceria: 7800 },
      { name: 'Baú De Especiarias', type: 'Item Ilegal', civil: 10400, parceria: 10400 },
      { name: 'Bomba 2.ª Guerra', type: 'Item Ilegal', civil: 16900, parceria: 16900 },
      { name: 'Adaga Templária', type: 'Item Ilegal', civil: 28600, parceria: 28600 },
      { name: 'Idolo Inca', type: 'Item Ilegal', civil: 260000, parceria: 260000 },

      { group: 'Material' },
      { name: 'Licença de Pesca', type: 'Material', civil: 50000, parceria: 50000, note: 'Segunda via: 10.000€' },
      { name: 'Minhoca', type: 'Material', civil: 400, parceria: 300 },
      { name: 'Armadilha', type: 'Material', civil: 75000, parceria: 45000 },
      { name: 'Cana de Pesca', type: 'Material', civil: 80000, parceria: 48000 },
      { name: 'Pager', type: 'Material', civil: 40000, parceria: 24000 }
    ]
  };

  const selected = {
    minas: new Map(),
    pesca: new Map()
  };

  const tabs = document.querySelectorAll('.other-craft-tab:not(.craft-tab-disabled)');
  const sections = document.querySelectorAll('[data-craft-section]');
  const processInputs = document.getElementById('processInputs');
  const processResults = document.getElementById('processResults');
  const processTotal = document.getElementById('processTotal');
  const processModeLabel = document.getElementById('processModeLabel');
  const pescaCategory = document.getElementById('pescaCategory');

  const labels = {
    civil: 'Civil / Sem equipa',
    equipa: 'Com equipa',
    parceria: 'Parceria'
  };

  function money(value) {
    return new Intl.NumberFormat('pt-PT').format(Math.round(Number(value || 0))) + '€';
  }

  function mode(scope) {
    const select = document.querySelector(`[data-mode-select="${scope}"]`);
    return select ? select.value : 'civil';
  }

  function price(item, scope) {
    const currentMode = mode(scope);
    return Number(item[currentMode] ?? item.civil ?? 0);
  }

  function saveState(scope) {
    const data = {
      mode: mode(scope),
      items: Array.from(selected[scope].values())
    };

    if (scope === 'minas') {
      data.processes = {};
      document.querySelectorAll('[data-process-input]').forEach(input => {
        data.processes[input.dataset.processInput] = Number(input.value || 0);
      });
    }

    localStorage.setItem(`outrosCrafts_${scope}`, JSON.stringify(data));

    const msg = document.getElementById(`${scope}SaveMessage`);
    if (msg) {
      msg.textContent = 'Guardado neste navegador.';
      setTimeout(() => msg.textContent = '', 2200);
    }
  }

  function loadState(scope) {
    try {
      const raw = localStorage.getItem(`outrosCrafts_${scope}`);
      if (!raw) return;

      const data = JSON.parse(raw);

      const modeSelect = document.querySelector(`[data-mode-select="${scope}"]`);
      if (modeSelect && data.mode) modeSelect.value = data.mode;

      selected[scope].clear();
      (data.items || []).forEach(item => selected[scope].set(item.name, item));

      if (scope === 'minas' && data.processes) {
        Object.entries(data.processes).forEach(([key, value]) => {
          const input = document.querySelector(`[data-process-input="${key}"]`);
          if (input) input.value = value;
        });
      }
    } catch (err) {
      console.warn('Erro ao carregar outros crafts:', err);
    }
  }

  function renderProcesses() {
    processInputs.innerHTML = PROCESS_RESOURCES.map(resource => `
      <div class="process-input-card">
        <label for="process_${resource.key}">${resource.name}</label>
        <input id="process_${resource.key}" data-process-input="${resource.key}" type="number" min="0" value="0">
      </div>
    `).join('');

    processInputs.querySelectorAll('input').forEach(input => {
      input.addEventListener('input', calculateProcesses);
    });
  }

  function calculateProcesses() {
    const currentMode = mode('minas');
    processModeLabel.textContent = labels[currentMode] || currentMode;

    let total = 0;

    processResults.innerHTML = PROCESS_RESOURCES.map(resource => {
      const input = document.querySelector(`[data-process-input="${resource.key}"]`);
      const qty = Number(input?.value || 0);
      const percent = Number(resource.percent[currentMode] || 0);
      const invoiceUnit = Number(resource.invoice[currentMode] || 0);

      const finalQty = Math.max(0, Math.floor(qty * (100 - percent) / 100));
      const removedQty = Math.max(0, qty - finalQty);
      const lineTotal = qty * invoiceUnit;

      total += lineTotal;

      return `
        <div class="process-result-row">
          <div>
            <strong>${resource.name}</strong>
            <small>Inserido: ${qty} • Retira: ${percent}% (${removedQty})</small>
          </div>

          <div class="process-output">
            <span>${resource.output}</span>
            <b>${finalQty}</b>
          </div>

          <div class="process-invoice">
            <span>Fatura</span>
            <b>${money(lineTotal)}</b>
          </div>
        </div>
      `;
    }).join('');

    processTotal.textContent = money(total);
  }

  function groupClass(group) {
    if (group === 'Peixe') return 'pesca-legal-title';
    if (group === 'Peixe Ilegal') return 'pesca-ilegal-title';
    if (group === 'Item Ilegal') return 'pesca-items-title';
    return 'pesca-material-title';
  }

  function renderSalesList(scope) {
    const el = document.getElementById(`${scope}SaleList`);
    const data = SALE_DATA[scope];

    el.innerHTML = data.map(item => {
      if (item.group) {
        return `<div class="craft-group-title ${groupClass(item.group)}" data-group-title="${item.group}">${item.group === 'Item Ilegal' ? 'Items Ilegais' : item.group}</div>`;
      }

      return `
        <div class="craft-card glass reveal-card" data-scope="${scope}" data-category="${item.type}" data-name="${item.name}">
          <div class="craft-card-info">
            <span class="craft-type">${item.type}</span>
            <h3>${item.name}</h3>
            <p>${item.note || 'Preço calculado pelo tipo selecionado.'}</p>
          </div>

          <div class="craft-card-side">
            <strong class="craft-price">${money(price(item, scope))}</strong>
            <button type="button" class="other-craft-add-btn">Adicionar</button>
          </div>
        </div>
      `;
    }).join('');

    el.querySelectorAll('.other-craft-add-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const card = btn.closest('.craft-card');
        const item = data.find(entry => entry.name === card.dataset.name);
        const current = selected[scope].get(item.name);

        selected[scope].set(item.name, {
          ...item,
          scope,
          qty: current ? current.qty + 1 : 1
        });

        card.classList.remove('craft-added-pulse');
        void card.offsetWidth;
        card.classList.add('craft-added-pulse');

        renderSummary(scope);
      });
    });

    applyPescaFilter();
    updatePrices();
  }

  function updatePrices() {
    document.querySelectorAll('.craft-card').forEach(card => {
      const scope = card.dataset.scope;
      const data = SALE_DATA[scope];
      if (!data) return;

      const item = data.find(entry => entry.name === card.dataset.name);
      const priceEl = card.querySelector('.craft-price');
      if (item && priceEl) priceEl.textContent = money(price(item, scope));
    });

    renderSummary('minas');
    renderSummary('pesca');
  }

  function renderSummary(scope) {
    const list = document.getElementById(`${scope}SaleSummary`);
    const totalEl = document.getElementById(`${scope}SaleTotal`);
    const items = Array.from(selected[scope].values());

    if (!items.length) {
      list.innerHTML = `<div class="empty-calc"><span class="empty-dot"></span>Ainda não adicionaste nenhum item.</div>`;
      totalEl.textContent = '0€';
      return;
    }

    let total = 0;

    list.innerHTML = items.map(item => {
      const unit = price(item, scope);
      const line = unit * item.qty;
      total += line;

      return `
        <div class="other-summary-item">
          <div class="other-summary-top">
            <div>
              <h3>${item.name}</h3>
              <p>${item.type} • ${money(unit)} unidade</p>
            </div>
            <strong>${money(line)}</strong>
          </div>

          <div class="calc-item-controls">
            <input type="number" min="1" value="${item.qty}" data-qty-scope="${scope}" data-qty-name="${item.name}">
            <button type="button" class="remove-btn" data-remove-scope="${scope}" data-remove-name="${item.name}">Remover</button>
          </div>
        </div>
      `;
    }).join('');

    totalEl.textContent = money(total);

    list.querySelectorAll('[data-qty-name]').forEach(input => {
      input.addEventListener('input', () => {
        const item = selected[input.dataset.qtyScope].get(input.dataset.qtyName);
        if (!item) return;

        item.qty = Math.max(1, Number(input.value || 1));
        selected[input.dataset.qtyScope].set(item.name, item);
        renderSummary(input.dataset.qtyScope);
      });
    });

    list.querySelectorAll('[data-remove-name]').forEach(button => {
      button.addEventListener('click', () => {
        selected[button.dataset.removeScope].delete(button.dataset.removeName);
        renderSummary(button.dataset.removeScope);
      });
    });
  }

  function applyPescaFilter() {
    if (!pescaCategory) return;

    const value = pescaCategory.value;

    document.querySelectorAll('[data-craft-section="pesca"] .craft-card').forEach(card => {
      card.style.display = value === 'todos' || card.dataset.category === value ? 'flex' : 'none';
    });

    document.querySelectorAll('[data-craft-section="pesca"] [data-group-title]').forEach(title => {
      title.style.display = value === 'todos' || title.dataset.groupTitle === value ? 'block' : 'none';
    });
  }

  function setActiveCraft(craft) {
    tabs.forEach(tab => tab.classList.toggle('active', tab.dataset.craft === craft));
    sections.forEach(section => section.classList.toggle('active', section.dataset.craftSection === craft));
  }

  tabs.forEach(tab => tab.addEventListener('click', () => setActiveCraft(tab.dataset.craft)));

  document.querySelectorAll('[data-mode-select]').forEach(select => {
    select.addEventListener('change', () => {
      updatePrices();
      calculateProcesses();
    });
  });

  if (pescaCategory) pescaCategory.addEventListener('change', applyPescaFilter);

  document.querySelectorAll('[data-save]').forEach(button => {
    button.addEventListener('click', () => saveState(button.dataset.save));
  });

  document.querySelectorAll('[data-clear]').forEach(button => {
    button.addEventListener('click', () => {
      const scope = button.dataset.clear;
      selected[scope].clear();
      localStorage.removeItem(`outrosCrafts_${scope}`);

      if (scope === 'minas') {
        document.querySelectorAll('[data-process-input]').forEach(input => {
          input.value = 0;
        });
        calculateProcesses();
      }

      renderSummary(scope);
    });
  });

  renderProcesses();
  renderSalesList('minas');
  renderSalesList('pesca');
  loadState('minas');
  loadState('pesca');
  updatePrices();
  calculateProcesses();
  setActiveCraft('minas');
});
</script>

<%- include('partials/footer') %>
