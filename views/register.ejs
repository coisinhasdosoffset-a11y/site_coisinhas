<%- include('partials/header', { page: 'register' }) %>

<section class="form-section">
  <div class="form-card glass">
    <h2>Criar Conta</h2>

    <div class="info-box">
      Estas informações não serão utilizadas para mais nada, apenas para teres a tua conta criada.
    </div>

    <% if (error) { %>
      <div class="info-box" style="border-left-color:#ff5959;">
        <%= error %>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="info-box" style="border-left-color:#13c296;">
        <%= success %>
      </div>
    <% } %>

    <form action="/register" method="POST">
      <input
        type="text"
        name="primeiro_nome"
        placeholder="Primeiro nome"
        required
      >

      <input
        type="text"
        name="ultimo_nome"
        placeholder="Último nome"
        required
      >

      <input
        type="text"
        name="username"
        placeholder="Username"
        required
      >

      <input
        type="password"
        name="password"
        placeholder="Password"
        required
      >

      <button type="submit" class="btn btn-primary">Criar Conta</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
