<%- include('partials/header', { page: 'login' }) %>

<section class="form-section">
  <div class="form-card glass">
    <h2>Nova Password Obrigatória</h2>

    <div class="info-box">
      Foi criada uma password temporária para a tua conta. Tens de escolher
      uma nova password para continuares a usar o site.
    </div>

    <% if (error) { %>
      <div class="info-box" style="border-left-color:#ff5959;">
        <%= error %>
      </div>
    <% } %>

    <form action="/force-password-change" method="POST">
      <input
        type="password"
        name="newPassword"
        placeholder="Nova password"
        required
      >

      <input
        type="password"
        name="confirmPassword"
        placeholder="Confirmar nova password"
        required
      >

      <button type="submit" class="btn btn-primary">Guardar nova password</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>