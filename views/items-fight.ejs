<%- include('partials/header', { page: 'items-fight' }) %>

<section class="barragem-shell">
  <div class="barragem-header glass">
    <div>
      <span class="barragem-tag">Items para Fight</span>
      <h1>Items para Fight</h1>
      <p class="barragem-subtitle">
        Calcula rapidamente os materiais necessários para items de combate.
      </p>
    </div>
  </div>

  <div class="barragem-grid">
    <div class="barragem-left">
      <div class="loot-list">
        <div
          class="loot-card glass item-fight-card"
          data-nome="Colete"
          data-recursos='{"fibra":5,"pele":3,"tecido":5,"couro":2,"estimulantes":0,"lata":0,"oleoMedicinal":0,"pecasBasicas":0,"dinheiro":6500}'
        >
          <div class="loot-info">
            <h3>1 Colete</h3>
            <p>5 fibra + 3 pele + 5 tecido + 2 couro + 6.500€</p>
          </div>

          <div class="loot-actions">
            <strong>6.500€</strong>
            <button type="button" class="add-item-btn">Adicionar</button>
          </div>
        </div>

        <div
          class="loot-card glass item-fight-card"
          data-nome="Energético"
          data-recursos='{"fibra":0,"pele":0,"tecido":0,"couro":0,"estimulantes":3,"lata":1,"oleoMedicinal":0,"pecasBasicas":0,"dinheiro":11000}'
        >
          <div class="loot-info">
            <h3>1 Energético</h3>
            <p>3 estimulantes + 1 lata + 11.000€</p>
          </div>

          <div class="loot-actions">
            <strong>11.000€</strong>
            <button type="button" class="add-item-btn">Adicionar</button>
          </div>
        </div>

        <div
          class="loot-card glass item-fight-card"
          data-nome="Medkit"
          data-recursos='{"fibra":0,"pele":0,"tecido":0,"couro":0,"estimulantes":0,"lata":0,"oleoMedicinal":5,"pecasBasicas":0,"dinheiro":40000}'
        >
          <div class="loot-info">
            <h3>1 Medkit</h3>
            <p>5 óleo medicinal + 40.000€</p>
          </div>

          <div class="loot-actions">
            <strong>40.000€</strong>
            <button type="button" class="add-item-btn">Adicionar</button>
          </div>
        </div>

        <div
          class="loot-card glass item-fight-card"
          data-nome="Lucille"
          data-recursos='{"fibra":0,"pele":0,"tecido":0,"couro":0,"estimulantes":0,"lata":0,"oleoMedicinal":0,"pecasBasicas":10,"dinheiro":10000}'
        >
          <div class="loot-info">
            <h3>1 Lucille</h3>
            <p>10 peças básicas + 10.000€</p>
          </div>

          <div class="loot-actions">
            <strong>10.000€</strong>
            <button type="button" class="add-item-btn">Adicionar</button>
          </div>
        </div>

        <div
          class="loot-card glass item-fight-card"
          data-nome="Taco de Beisebol"
          data-recursos='{"fibra":0,"pele":0,"tecido":0,"couro":0,"estimulantes":0,"lata":0,"oleoMedicinal":0,"pecasBasicas":10,"dinheiro":10000}'
        >
          <div class="loot-info">
            <h3>1 Taco de Beisebol</h3>
            <p>10 peças básicas + 10.000€</p>
          </div>

          <div class="loot-actions">
            <strong>10.000€</strong>
            <button type="button" class="add-item-btn">Adicionar</button>
          </div>
        </div>
      </div>
    </div>

    <div class="barragem-right">
      <div class="calc-panel glass">
        <div class="calc-head">
          <span class="barragem-tag">Resumo</span>
          <h2>Cálculo atual</h2>
        </div>

        <div id="fight-calc-items" class="calc-items">
          <div class="empty-calc">
            <span class="empty-dot"></span>
            Ainda não adicionaste nenhum item.
          </div>
        </div>

        <div class="calc-summary">
          <div class="summary-row">
            <span>Fibra</span>
            <strong id="fight-total-fibra">0</strong>
          </div>
          <div class="summary-row">
            <span>Pele</span>
            <strong id="fight-total-pele">0</strong>
          </div>
          <div class="summary-row">
            <span>Tecido</span>
            <strong id="fight-total-tecido">0</strong>
          </div>
          <div class="summary-row">
            <span>Couro</span>
            <strong id="fight-total-couro">0</strong>
          </div>
          <div class="summary-row">
            <span>Estimulantes</span>
            <strong id="fight-total-estimulantes">0</strong>
          </div>
          <div class="summary-row">
            <span>Lata</span>
            <strong id="fight-total-lata">0</strong>
          </div>
          <div class="summary-row">
            <span>Óleo Medicinal</span>
            <strong id="fight-total-oleo">0</strong>
          </div>
          <div class="summary-row">
            <span>Peças Básicas</span>
            <strong id="fight-total-pb">0</strong>
          </div>
          <div class="summary-row">
            <span>Dinheiro</span>
            <strong id="fight-total-dinheiro">0€</strong>
          </div>
        </div>

        <div class="calc-actions">
          <button type="button" class="btn btn-primary" id="fight-save-btn">Guardar</button>
          <button type="button" class="btn btn-danger" id="fight-clear-btn">Limpar</button>
        </div>

        <p id="fight-save-message" class="save-message"></p>
      </div>
    </div>
  </div>
</section>

<script>
  const fightCards = document.querySelectorAll('.item-fight-card');
  const fightCalcItems = document.getElementById('fight-calc-items');
  const fightSaveBtn = document.getElementById('fight-save-btn');
  const fightClearBtn = document.getElementById('fight-clear-btn');
  const fightSaveMessage = document.getElementById('fight-save-message');

  const totalFibraEl = document.getElementById('fight-total-fibra');
  const totalPeleEl = document.getElementById('fight-total-pele');
  const totalTecidoEl = document.getElementById('fight-total-tecido');
  const totalCouroEl = document.getElementById('fight-total-couro');
  const totalEstimulantesEl = document.getElementById('fight-total-estimulantes');
  const totalLataEl = document.getElementById('fight-total-lata');
  const totalOleoEl = document.getElementById('fight-total-oleo');
  const totalPBEl = document.getElementById('fight-total-pb');
  const totalDinheiroEl = document.getElementById('fight-total-dinheiro');

  const selecionados = {};
  const calculosGuardados = <%- JSON.stringify(typeof calculos !== 'undefined' ? calculos : []) %>;

  function formatarEuro(valor) {
    return Number(valor).toLocaleString('pt-PT') + '€';
  }

  function formatarNumero(valor) {
    return Number(valor).toLocaleString('pt-PT');
  }

  function calcularTotaisFight() {
    const total = {
      fibra: 0,
      pele: 0,
      tecido: 0,
      couro: 0,
      estimulantes: 0,
      lata: 0,
      oleoMedicinal: 0,
      pecasBasicas: 0,
      dinheiro: 0
    };

    Object.values(selecionados).forEach((item) => {
      total.fibra += item.recursos.fibra * item.quantidade;
      total.pele += item.recursos.pele * item.quantidade;
      total.tecido += item.recursos.tecido * item.quantidade;
      total.couro += item.recursos.couro * item.quantidade;
      total.estimulantes += item.recursos.estimulantes * item.quantidade;
      total.lata += item.recursos.lata * item.quantidade;
      total.oleoMedicinal += item.recursos.oleoMedicinal * item.quantidade;
      total.pecasBasicas += item.recursos.pecasBasicas * item.quantidade;
      total.dinheiro += item.recursos.dinheiro * item.quantidade;
    });

    return total;
  }

  function renderFight() {
    const lista = Object.values(selecionados);

    if (lista.length === 0) {
      fightCalcItems.innerHTML = `
        <div class="empty-calc">
          <span class="empty-dot"></span>
          Ainda não adicionaste nenhum item.
        </div>
      `;
    } else {
      fightCalcItems.innerHTML = lista.map((item) => `
        <div class="calc-item">
          <div class="calc-item-top">
            <div>
              <h3>${item.nome}</h3>
              <p>Item de combate</p>
            </div>
            <div class="calc-item-total">${item.quantidade}x</div>
          </div>

          <p style="margin-bottom: 12px; color: #d7d7d7;">
            ${descreverRecursosFight(item.recursos, item.quantidade)}
          </p>

          <div class="calc-item-controls">
            <input
              type="text"
              inputmode="numeric"
              value="${item.quantidade}"
              data-key="${item.nome}"
              class="fight-qty-input"
            >
            <button type="button" class="remove-btn fight-remove-btn" data-key="${item.nome}">
              Remover
            </button>
          </div>
        </div>
      `).join('');
    }

    const total = calcularTotaisFight();

    totalFibraEl.textContent = formatarNumero(total.fibra);
    totalPeleEl.textContent = formatarNumero(total.pele);
    totalTecidoEl.textContent = formatarNumero(total.tecido);
    totalCouroEl.textContent = formatarNumero(total.couro);
    totalEstimulantesEl.textContent = formatarNumero(total.estimulantes);
    totalLataEl.textContent = formatarNumero(total.lata);
    totalOleoEl.textContent = formatarNumero(total.oleoMedicinal);
    totalPBEl.textContent = formatarNumero(total.pecasBasicas);
    totalDinheiroEl.textContent = formatarEuro(total.dinheiro);

    ligarEventosFight();
  }

  function descreverRecursosFight(recursos, quantidade) {
    const partes = [];

    if (recursos.fibra) partes.push(`${formatarNumero(recursos.fibra * quantidade)} fibra`);
    if (recursos.pele) partes.push(`${formatarNumero(recursos.pele * quantidade)} pele`);
    if (recursos.tecido) partes.push(`${formatarNumero(recursos.tecido * quantidade)} tecido`);
    if (recursos.couro) partes.push(`${formatarNumero(recursos.couro * quantidade)} couro`);
    if (recursos.estimulantes) partes.push(`${formatarNumero(recursos.estimulantes * quantidade)} estimulantes`);
    if (recursos.lata) partes.push(`${formatarNumero(recursos.lata * quantidade)} lata`);
    if (recursos.oleoMedicinal) partes.push(`${formatarNumero(recursos.oleoMedicinal * quantidade)} óleo medicinal`);
    if (recursos.pecasBasicas) partes.push(`${formatarNumero(recursos.pecasBasicas * quantidade)} peças básicas`);
    if (recursos.dinheiro) partes.push(`${formatarEuro(recursos.dinheiro * quantidade)}`);

    return partes.join(' + ');
  }

  function ligarEventosFight() {
    document.querySelectorAll('.fight-qty-input').forEach((input) => {
      input.addEventListener('input', (e) => {
        const key = e.target.dataset.key;
        const limpo = e.target.value.replace(/[^0-9]/g, '');
        e.target.value = limpo;

        if (limpo !== '') {
          selecionados[key].quantidade = parseInt(limpo, 10);
          renderFight();
        }
      });

      input.addEventListener('blur', (e) => {
        const key = e.target.dataset.key;
        if (!e.target.value || Number(e.target.value) < 1) {
          selecionados[key].quantidade = 1;
          renderFight();
        }
      });
    });

    document.querySelectorAll('.fight-remove-btn').forEach((button) => {
      button.addEventListener('click', (e) => {
        const key = e.target.dataset.key;
        delete selecionados[key];
        renderFight();
      });
    });
  }

  fightCards.forEach((card) => {
    const button = card.querySelector('.add-item-btn');

    button.addEventListener('click', () => {
      const nome = card.dataset.nome;
      const recursos = JSON.parse(card.dataset.recursos);

      card.classList.add('pulse-added');
      setTimeout(() => card.classList.remove('pulse-added'), 450);

      if (!selecionados[nome]) {
        selecionados[nome] = {
          nome,
          quantidade: 1,
          recursos
        };
      } else {
        selecionados[nome].quantidade += 1;
      }

      renderFight();
    });
  });

  fightSaveBtn.addEventListener('click', async () => {
    const items = Object.values(selecionados);

    if (items.length === 0) {
      fightSaveMessage.textContent = 'Não tens items para guardar.';
      return;
    }

    try {
      const response = await fetch('/items-fight/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items })
      });

      const data = await response.json();

      if (data.success) {
        fightSaveMessage.textContent = 'Cálculo guardado com sucesso.';
      } else {
        fightSaveMessage.textContent = 'Erro ao guardar cálculo.';
      }
    } catch (error) {
      fightSaveMessage.textContent = 'Erro ao guardar cálculo.';
    }
  });

  fightClearBtn.addEventListener('click', async () => {
    Object.keys(selecionados).forEach((key) => delete selecionados[key]);
    renderFight();

    try {
      await fetch('/items-fight/clear', { method: 'POST' });
      fightSaveMessage.textContent = 'Cálculo limpo.';
    } catch (error) {
      fightSaveMessage.textContent = 'Erro ao limpar cálculo.';
    }
  });

  if (calculosGuardados.length > 0) {
    calculosGuardados.forEach((item) => {
      selecionados[item.nome_item] = {
        nome: item.nome_item,
        quantidade: Number(item.quantidade),
        recursos: {
          fibra: Number(item.fibra || 0),
          pele: Number(item.pele || 0),
          tecido: Number(item.tecido || 0),
          couro: Number(item.couro || 0),
          estimulantes: Number(item.estimulantes || 0),
          lata: Number(item.lata || 0),
          oleoMedicinal: Number(item.oleo_medicinal || 0),
          pecasBasicas: Number(item.pecas_basicas || 0),
          dinheiro: Number(item.dinheiro || 0)
        }
      };
    });
  }

  renderFight();
</script>

<%- include('partials/footer') %>