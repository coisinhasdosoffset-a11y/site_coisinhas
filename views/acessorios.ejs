<script>
  const accessoryItems = document.querySelectorAll('.accessory-item');
  const accessoryAddButtons = document.querySelectorAll('.accessory-add-btn');
  const accessoriesCalcItems = document.getElementById('accessories-calc-items');
  const accSaveBtn = document.getElementById('acc-save-btn');
  const accClearBtn = document.getElementById('acc-clear-btn');
  const accSaveMessage = document.getElementById('acc-save-message');
  const acessorioArmaFilter = document.getElementById('acessorio-arma-filter');

  const accTotalDinheiro = document.getElementById('acc-total-dinheiro');
  const accTotalAluminio = document.getElementById('acc-total-aluminio');
  const accTotalPlastico = document.getElementById('acc-total-plastico');
  const accTotalAco = document.getElementById('acc-total-aco');
  const accTotalRestos = document.getElementById('acc-total-restos');

  const selecionados = {};
  const calculosGuardados = <%- JSON.stringify(typeof calculos !== 'undefined' ? calculos : []) %>;

  function formatarEuro(valor) {
    return Number(valor).toLocaleString('pt-PT') + '€';
  }

  function formatarNumero(valor) {
    return Number(valor).toLocaleString('pt-PT');
  }

  function obterTotaisAcessorios() {
    const totais = {
      dinheiroSujo: 0,
      aluminio: 0,
      plastico: 0,
      aco: 0,
      restos: 0
    };

    Object.values(selecionados).forEach(item => {
      totais.dinheiroSujo += (item.recursos.dinheiroSujo || 0) * item.quantidade;
      totais.aluminio += (item.recursos.aluminio || 0) * item.quantidade;
      totais.plastico += (item.recursos.plastico || 0) * item.quantidade;
      totais.aco += (item.recursos.aco || 0) * item.quantidade;
      totais.restos += (item.recursos.restos || 0) * item.quantidade;
    });

    return totais;
  }

  function atualizarResumoAcessorios() {
    const totais = obterTotaisAcessorios();

    accTotalDinheiro.textContent = formatarEuro(totais.dinheiroSujo);
    accTotalAluminio.textContent = formatarNumero(totais.aluminio);
    accTotalPlastico.textContent = formatarNumero(totais.plastico);
    accTotalAco.textContent = formatarNumero(totais.aco);
    accTotalRestos.textContent = formatarNumero(totais.restos);
  }

  function textoRecursosAcessorios(recursos, quantidade) {
    const partes = [];

    if (recursos.dinheiroSujo) partes.push(formatarEuro(recursos.dinheiroSujo * quantidade));
    if (recursos.aluminio) partes.push(`${formatarNumero(recursos.aluminio * quantidade)} alumínio`);
    if (recursos.plastico) partes.push(`${formatarNumero(recursos.plastico * quantidade)} plástico`);
    if (recursos.aco) partes.push(`${formatarNumero(recursos.aco * quantidade)} aço`);
    if (recursos.restos) partes.push(`${formatarNumero(recursos.restos * quantidade)} restos`);

    return partes.join(' + ');
  }

  function ligarEventosCalcAcessorios() {
    document.querySelectorAll('.acc-qty-input').forEach(input => {
      input.addEventListener('input', (e) => {
        const key = e.target.dataset.key;
        const limpo = e.target.value.replace(/[^0-9]/g, '');
        e.target.value = limpo;

        if (limpo !== '') {
          selecionados[key].quantidade = parseInt(limpo, 10);
          renderCalcAcessorios();
        }
      });

      input.addEventListener('blur', (e) => {
        const key = e.target.dataset.key;
        if (!e.target.value || Number(e.target.value) < 1) {
          selecionados[key].quantidade = 1;
          renderCalcAcessorios();
        }
      });
    });

    document.querySelectorAll('.acc-remove-btn').forEach(button => {
      button.addEventListener('click', (e) => {
        const key = e.target.dataset.key;
        delete selecionados[key];
        renderCalcAcessorios();
      });
    });
  }

  function renderCalcAcessorios() {
    const itens = Object.values(selecionados);

    if (itens.length === 0) {
      accessoriesCalcItems.innerHTML = `
        <div class="empty-calc">
          <span class="empty-dot"></span>
          Ainda não adicionaste nenhum item.
        </div>
      `;
    } else {
      accessoriesCalcItems.innerHTML = itens.map(item => `
        <div class="calc-item">
          <div class="calc-item-top">
            <div>
              <h3>${item.nome}</h3>
              <p>${item.categoria}</p>
            </div>
            <div class="calc-item-total">${item.quantidade}x</div>
          </div>

          <p style="margin-bottom: 12px; color: #d7d7d7;">
            ${textoRecursosAcessorios(item.recursos, item.quantidade)}
          </p>

          <div class="calc-item-controls">
            <input
              type="text"
              inputmode="numeric"
              value="${item.quantidade}"
              data-key="${item.nome}__${item.categoria}"
              class="acc-qty-input"
            >
            <button type="button" class="remove-btn acc-remove-btn" data-key="${item.nome}__${item.categoria}">
              Remover
            </button>
          </div>
        </div>
      `).join('');
    }

    atualizarResumoAcessorios();
    ligarEventosCalcAcessorios();
  }

  accessoryAddButtons.forEach(button => {
    button.addEventListener('click', (e) => {
      const card = e.target.closest('.accessory-item');
      const nome = card.dataset.nome;
      const categoria = card.dataset.categoria;
      const recursos = JSON.parse(card.dataset.recursos);
      const key = `${nome}__${categoria}`;

      card.classList.add('accessory-pulse');
      setTimeout(() => card.classList.remove('accessory-pulse'), 450);

      if (selecionados[key]) {
        selecionados[key].quantidade += 1;
      } else {
        selecionados[key] = {
          nome,
          categoria,
          quantidade: 1,
          recursos: {
            dinheiroSujo: recursos.dinheiroSujo || 0,
            aluminio: recursos.aluminio || 0,
            plastico: recursos.plastico || 0,
            aco: recursos.aco || 0,
            restos: recursos.restos || 0
          }
        };
      }

      renderCalcAcessorios();
    });
  });

  acessorioArmaFilter.addEventListener('change', () => {
    const valor = acessorioArmaFilter.value;

    accessoryItems.forEach(card => {
      const armas = card.dataset.armas.split('|').map(item => item.trim());

      if (valor === 'all' || armas.includes(valor)) {
        card.style.display = 'flex';
      } else {
        card.style.display = 'none';
      }
    });
  });

  accSaveBtn.addEventListener('click', async () => {
    const items = Object.values(selecionados);

    if (items.length === 0) {
      accSaveMessage.textContent = 'Não tens itens para guardar.';
      return;
    }

    const response = await fetch('/acessorios/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items })
    });

    const data = await response.json();

    if (data.success) {
      accSaveMessage.textContent = 'Cálculo guardado com sucesso.';
    } else {
      accSaveMessage.textContent = 'Erro ao guardar cálculo.';
    }
  });

  accClearBtn.addEventListener('click', async () => {
    Object.keys(selecionados).forEach(key => delete selecionados[key]);
    renderCalcAcessorios();

    await fetch('/acessorios/clear', {
      method: 'POST'
    });

    accSaveMessage.textContent = 'Cálculo limpo.';
  });

  if (calculosGuardados.length > 0) {
    calculosGuardados.forEach(item => {
      const key = `${item.nome_item}__${item.categoria}`;

      selecionados[key] = {
        nome: item.nome_item,
        categoria: item.categoria,
        quantidade: Number(item.quantidade),
        recursos: {
          dinheiroSujo: Number(item.dinheiro_sujo || 0),
          aluminio: Number(item.aluminio || 0),
          plastico: Number(item.plastico || 0),
          aco: Number(item.aco || 0),
          restos: Number(item.restos || 0)
        }
      };
    });
  }

  renderCalcAcessorios();
</script>





<script>
document.addEventListener('DOMContentLoaded', () => {
  const filterButtons = document.querySelectorAll('.accessory-filter-btn');
  const accessoryCards = document.querySelectorAll('.accessory-card');
  const groupTitles = document.querySelectorAll('.accessory-group-title');
  const weaponSelect = document.querySelector('.accessories-filter-box select');

  function norm(value) {
    return String(value || '').trim().toLowerCase();
  }

  function getCategory(card) {
    return card.dataset.categoria || card.dataset.category || card.dataset.type || '';
  }

  function getWeaponText(card) {
    const text = card.innerText || '';
    return norm(text);
  }

  function getActiveCategory() {
    const activeButton = document.querySelector('.accessory-filter-btn.active');
    return activeButton ? activeButton.dataset.filter : 'Pistola';
  }

  function getSelectedWeapon() {
    if (!weaponSelect) return 'Todas';
    const selectedOption = weaponSelect.options[weaponSelect.selectedIndex];
    return selectedOption ? selectedOption.textContent.trim() : weaponSelect.value;
  }

  function updateWeaponOptions(category) {
    if (!weaponSelect) return;

    const current = weaponSelect.value;
    const options = Array.from(weaponSelect.options);

    options.forEach(option => {
      const text = norm(option.textContent);
      const value = norm(option.value);

      if (text === 'todas' || value === 'todas') {
        option.hidden = false;
        option.disabled = false;
        return;
      }

      let hasMatch = false;

      accessoryCards.forEach(card => {
        const cardCategory = norm(getCategory(card));
        const cardText = getWeaponText(card);

        if (cardCategory === norm(category) && cardText.includes(text)) {
          hasMatch = true;
        }
      });

      option.hidden = !hasMatch;
      option.disabled = !hasMatch;
    });

    const selected = weaponSelect.options[weaponSelect.selectedIndex];

    if (!selected || selected.disabled || selected.hidden) {
      const todas = options.find(option => norm(option.textContent) === 'todas' || norm(option.value) === 'todas');
      if (todas) {
        weaponSelect.value = todas.value;
      } else {
        const firstAvailable = options.find(option => !option.disabled && !option.hidden);
        if (firstAvailable) weaponSelect.value = firstAvailable.value;
      }
    } else {
      weaponSelect.value = current;
    }
  }

  function applyFilters() {
    const category = getActiveCategory();
    const weapon = getSelectedWeapon();

    updateWeaponOptions(category);

    const categoryNorm = norm(category);
    const weaponNorm = norm(weapon);
    const allWeapons = weaponNorm === 'todas' || weaponNorm === 'todos' || weaponNorm === '';

    accessoryCards.forEach(card => {
      const cardCategory = norm(getCategory(card));
      const cardText = getWeaponText(card);

      const matchesCategory = cardCategory === categoryNorm;
      const matchesWeapon = allWeapons || cardText.includes(weaponNorm);

      card.style.display = matchesCategory && matchesWeapon ? 'flex' : 'none';
    });

    groupTitles.forEach(title => {
      const titleNorm = norm(title.textContent);
      title.style.display = titleNorm === categoryNorm ? 'block' : 'none';
    });
  }

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      filterButtons.forEach(btn => btn.classList.remove('active'));
      button.classList.add('active');
      applyFilters();
    });
  });

  if (weaponSelect) {
    weaponSelect.addEventListener('change', applyFilters);
  }

  applyFilters();
});
</script>

