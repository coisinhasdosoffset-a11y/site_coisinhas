    body.armas main.page {
      height: calc(100vh - 150px);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    body.armas .weapons-page {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
    }

    body.armas .weapons-hero {
      flex-shrink: 0;
    }

    body.armas .weapons-layout {
      flex: 1;
      min-height: 0;
      align-items: stretch;
    }

    body.armas .weapons-left,
    body.armas .weapons-right {
      min-height: 0;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    body.armas .weapon-tab-panel.active,
    body.armas .weapon-calc-panel {
      flex: 1;
      min-height: 0;
      overflow: hidden;
    }

    body.armas .weapon-tab-panel .weapons-list,
    body.armas .weapon-calc-panel {
      overflow-y: auto;
      padding-right: 8px;
    }

    body.armas .weapon-card {
      flex-shrink: 0;
    }
  }

  @media (max-width: 1100px) {
    .weapon-tab-panel.active {
      display: flex;
    }
  }
</style>

<script>
  const weaponAddButtons = document.querySelectorAll('.weapon-add-btn');
  const weaponCalcItems = document.getElementById('weapon-calc-items');
  const weaponSaveBtn = document.getElementById('weapon-save-btn');
  const weaponClearBtn = document.getElementById('weapon-clear-btn');
  const weaponSaveMessage = document.getElementById('weapon-save-message');
  const weaponArmasFilter = document.getElementById('weapon-armas-filter');
  const armasCards = document.querySelectorAll('.armas-card');
  const weaponTabButtons = document.querySelectorAll('.weapon-tab-btn');
  const weaponTabPanels = document.querySelectorAll('.weapon-tab-panel');

  weaponTabButtons.forEach(button => {
    button.addEventListener('click', () => {
      const target = button.dataset.tab;

      weaponTabButtons.forEach(btn => btn.classList.remove('active'));
      button.classList.add('active');

      weaponTabPanels.forEach(panel => {
        panel.classList.toggle('active', panel.dataset.tabPanel === target);
      });
    });
  });

  const totalDinheiro = document.getElementById('weapon-total-dinheiro');
  const totalDroga = document.getElementById('weapon-total-droga');
  const totalAbs = document.getElementById('weapon-total-abs');
  const totalAluminio = document.getElementById('weapon-total-aluminio');
  const totalBorracha = document.getElementById('weapon-total-borracha');
  const totalMetal = document.getElementById('weapon-total-metal');
  const totalAco = document.getElementById('weapon-total-aco');
  const totalPolimero = document.getElementById('weapon-total-polimero');
  const totalBronze = document.getElementById('weapon-total-bronze');
  const totalBP = document.getElementById('weapon-total-bp');
  const totalBS = document.getElementById('weapon-total-bs');
  const totalBR = document.getElementById('weapon-total-br');
  const totalPB = document.getElementById('weapon-total-pb');
  const totalPA = document.getElementById('weapon-total-pa');

  const selecionados = {};
  const calculosGuardados = <%- JSON.stringify(typeof calculos !== 'undefined' ? calculos : []) %>;

  function formatarEuro(valor) {
    return Number(valor).toLocaleString('pt-PT') + '€';
  }

  function formatarNumero(valor) {
    return Number(valor).toLocaleString('pt-PT');
  }

  function calcularMateriaisDerivados(totaisBase) {
    const derivados = {
      dinheiro: totaisBase.dinheiro,
      pacoteDroga: totaisBase.pacoteDroga,
      abs: totaisBase.abs,
      aluminio: totaisBase.aluminio,
      borracha: totaisBase.borracha,
      metal: totaisBase.metal,
      aco: totaisBase.aco,
      polimero: totaisBase.polimero,
      bronze: totaisBase.bronze,
      blueprintPistola: totaisBase.blueprintPistola,
      blueprintSmg: totaisBase.blueprintSmg,
      blueprintRifle: totaisBase.blueprintRifle,
      pecasBasicas: totaisBase.pecasBasicas,
      pecasAvancadas: totaisBase.pecasAvancadas
    };

    const packsPB = derivados.pecasBasicas / 2;
    const packsPA = derivados.pecasAvancadas / 2;

    derivados.dinheiro += packsPB * 400;
    derivados.abs += packsPB * 2;
    derivados.aluminio += packsPB * 1;
    derivados.borracha += packsPB * 1;
    derivados.metal += packsPB * 2;

    derivados.dinheiro += packsPA * 600;
    derivados.aluminio += packsPA * 1;
    derivados.borracha += packsPA * 1;
    derivados.aco += packsPA * 2;
    derivados.polimero += packsPA * 1;
    derivados.bronze += packsPA * 1;

    const packsBP = derivados.blueprintPistola / 6;
    const packsBS = derivados.blueprintSmg / 6;
    const packsBR = derivados.blueprintRifle / 6;

    derivados.pacoteDroga += packsBP * 2;
    derivados.pacoteDroga += packsBS * 2;
    derivados.pacoteDroga += packsBR * 2;

    return derivados;
  }

  function totaisArmas() {
    const base = {
      dinheiro: 0,
      pacoteDroga: 0,
      abs: 0,
      aluminio: 0,
      borracha: 0,
      metal: 0,
      aco: 0,
      polimero: 0,
      bronze: 0,
      blueprintPistola: 0,
      blueprintSmg: 0,
      blueprintRifle: 0,
      pecasBasicas: 0,
      pecasAvancadas: 0
    };

    Object.values(selecionados).forEach(item => {
      const q = item.quantidade;
      base.dinheiro += (item.recursos.dinheiro || 0) * q;
      base.pacoteDroga += (item.recursos.pacoteDroga || 0) * q;
      base.abs += (item.recursos.abs || 0) * q;
      base.aluminio += (item.recursos.aluminio || 0) * q;
      base.borracha += (item.recursos.borracha || 0) * q;
      base.metal += (item.recursos.metal || 0) * q;
      base.aco += (item.recursos.aco || 0) * q;
      base.polimero += (item.recursos.polimero || 0) * q;
      base.bronze += (item.recursos.bronze || 0) * q;
      base.blueprintPistola += (item.recursos.blueprintPistola || 0) * q;
      base.blueprintSmg += (item.recursos.blueprintSmg || 0) * q;
      base.blueprintRifle += (item.recursos.blueprintRifle || 0) * q;
      base.pecasBasicas += (item.recursos.pecasBasicas || 0) * q;
      base.pecasAvancadas += (item.recursos.pecasAvancadas || 0) * q;
    });

    return calcularMateriaisDerivados(base);
  }

  function atualizarResumoArmas() {
    const totais = totaisArmas();

    totalDinheiro.textContent = formatarEuro(totais.dinheiro);
    totalDroga.textContent = formatarNumero(totais.pacoteDroga);
    totalAbs.textContent = formatarNumero(totais.abs);
    totalAluminio.textContent = formatarNumero(totais.aluminio);
    totalBorracha.textContent = formatarNumero(totais.borracha);
    totalMetal.textContent = formatarNumero(totais.metal);
    totalAco.textContent = formatarNumero(totais.aco);
    totalPolimero.textContent = formatarNumero(totais.polimero);
    totalBronze.textContent = formatarNumero(totais.bronze);
    totalBP.textContent = formatarNumero(totais.blueprintPistola);
    totalBS.textContent = formatarNumero(totais.blueprintSmg);
    totalBR.textContent = formatarNumero(totais.blueprintRifle);
    totalPB.textContent = formatarNumero(totais.pecasBasicas);
    totalPA.textContent = formatarNumero(totais.pecasAvancadas);
  }

  function textoRecursos(recursos, quantidade) {
    const partes = [];

    if (recursos.dinheiro) partes.push(formatarEuro(recursos.dinheiro * quantidade));
    if (recursos.pacoteDroga) partes.push(`${formatarNumero(recursos.pacoteDroga * quantidade)} pacote(s) de droga`);
    if (recursos.abs) partes.push(`${formatarNumero(recursos.abs * quantidade)} ABS`);
    if (recursos.aluminio) partes.push(`${formatarNumero(recursos.aluminio * quantidade)} alumínio`);
    if (recursos.borracha) partes.push(`${formatarNumero(recursos.borracha * quantidade)} borracha`);
    if (recursos.metal) partes.push(`${formatarNumero(recursos.metal * quantidade)} metal`);
    if (recursos.aco) partes.push(`${formatarNumero(recursos.aco * quantidade)} aço`);
    if (recursos.polimero) partes.push(`${formatarNumero(recursos.polimero * quantidade)} polímero`);
    if (recursos.bronze) partes.push(`${formatarNumero(recursos.bronze * quantidade)} bronze`);
    if (recursos.blueprintPistola) partes.push(`${formatarNumero(recursos.blueprintPistola * quantidade)} blueprint(s) pistola`);
    if (recursos.blueprintSmg) partes.push(`${formatarNumero(recursos.blueprintSmg * quantidade)} blueprint(s) SMG`);
    if (recursos.blueprintRifle) partes.push(`${formatarNumero(recursos.blueprintRifle * quantidade)} blueprint(s) rifle`);
    if (recursos.pecasBasicas) partes.push(`${formatarNumero(recursos.pecasBasicas * quantidade)} peça(s) básicas`);
    if (recursos.pecasAvancadas) partes.push(`${formatarNumero(recursos.pecasAvancadas * quantidade)} peça(s) avançadas`);

    return partes.join(' + ');
  }

  function ligarEventosCalcArmas() {
    document.querySelectorAll('.weapon-qty-input').forEach(input => {
      input.addEventListener('input', (e) => {
        const key = e.target.dataset.key;
        const limpo = e.target.value.replace(/[^0-9]/g, '');
        e.target.value = limpo;

        if (limpo !== '') {
          selecionados[key].quantidade = parseInt(limpo, 10);
          renderCalcArmas();
        }
      });

      input.addEventListener('blur', (e) => {
        const key = e.target.dataset.key;
        if (!e.target.value || Number(e.target.value) < 1) {
          selecionados[key].quantidade = 1;
          renderCalcArmas();
        }
      });
    });

    document.querySelectorAll('.weapon-remove-btn').forEach(button => {
      button.addEventListener('click', (e) => {
        const key = e.target.dataset.key;
        delete selecionados[key];
        renderCalcArmas();
      });
    });
  }

  function renderCalcArmas() {
    const itens = Object.values(selecionados);

    if (itens.length === 0) {
      weaponCalcItems.innerHTML = `
        <div class="empty-calc">
          <span class="empty-dot"></span>
          Ainda não adicionaste nenhum item.
        </div>
      `;
    } else {
      weaponCalcItems.innerHTML = itens.map(item => `
        <div class="calc-item">
          <div class="calc-item-top">
            <div>
              <h3>${item.nome}</h3>
              <p>${item.tipoSecao}</p>
            </div>
            <div class="calc-item-total">${item.quantidade}x</div>
          </div>

          <p style="margin-bottom: 12px; color: #d7d7d7;">
            ${textoRecursos(item.recursos, item.quantidade)}
          </p>

          <div class="calc-item-controls">
            <input
              type="text"
              inputmode="numeric"
              value="${item.quantidade}"
              data-key="${item.nome}"
              class="weapon-qty-input"
            >
            <button type="button" class="remove-btn weapon-remove-btn" data-key="${item.nome}">
              Remover
            </button>
          </div>
        </div>
      `).join('');
    }

    atualizarResumoArmas();
    ligarEventosCalcArmas();
  }

  weaponAddButtons.forEach(button => {
    button.addEventListener('click', (e) => {
      const card = e.target.closest('.weapon-card');
      const nome = card.dataset.nome;
      const tipoSecao = card.dataset.secao;
      const recursos = JSON.parse(card.dataset.recursos);

      card.classList.add('weapon-pulse');
      setTimeout(() => card.classList.remove('weapon-pulse'), 450);

      if (selecionados[nome]) {
        selecionados[nome].quantidade += 1;
      } else {
        selecionados[nome] = {
          nome,
          tipoSecao,
          quantidade: 1,
          recursos: {
            dinheiro: recursos.dinheiro || 0,
            abs: recursos.abs || 0,
            aluminio: recursos.aluminio || 0,
            borracha: recursos.borracha || 0,
            metal: recursos.metal || 0,
            aco: recursos.aco || 0,
            polimero: recursos.polimero || 0,
            bronze: recursos.bronze || 0,
            pacoteDroga: recursos.pacoteDroga || 0,
            blueprintPistola: recursos.blueprintPistola || 0,
            blueprintSmg: recursos.blueprintSmg || 0,
            blueprintRifle: recursos.blueprintRifle || 0,
            pecasBasicas: recursos.pecasBasicas || 0,
            pecasAvancadas: recursos.pecasAvancadas || 0
          }
        };
      }

      renderCalcArmas();
    });
  });

  if (weaponArmasFilter) {
    weaponArmasFilter.addEventListener('change', () => {
      const valor = weaponArmasFilter.value;

      armasCards.forEach(card => {
        const grupo = card.dataset.grupo;

        if (valor === 'all' || grupo === valor) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
    });
  }

  weaponSaveBtn.addEventListener('click', async () => {
    const items = Object.values(selecionados);

    if (items.length === 0) {
      weaponSaveMessage.textContent = 'Não tens itens para guardar.';
      return;
    }

    const response = await fetch('/armas/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items })
    });

    const data = await response.json();

    if (data.success) {
      weaponSaveMessage.textContent = 'Cálculo guardado com sucesso.';
    } else {
      weaponSaveMessage.textContent = 'Erro ao guardar cálculo.';
    }
  });

  weaponClearBtn.addEventListener('click', async () => {
    Object.keys(selecionados).forEach(key => delete selecionados[key]);
    renderCalcArmas();

    await fetch('/armas/clear', {
      method: 'POST'
    });

    weaponSaveMessage.textContent = 'Cálculo limpo.';
  });

  if (calculosGuardados.length > 0) {
    calculosGuardados.forEach(item => {
      selecionados[item.nome_item] = {
        nome: item.nome_item,
        tipoSecao: item.tipo_secao,
        quantidade: Number(item.quantidade),
        recursos: {
          dinheiro: Number(item.dinheiro || 0),
          abs: Number(item.abs || 0),
          aluminio: Number(item.aluminio || 0),
          borracha: Number(item.borracha || 0),
          metal: Number(item.metal || 0),
          aco: Number(item.aco || 0),
          polimero: Number(item.polimero || 0),
          bronze: Number(item.bronze || 0),
          pacoteDroga: Number(item.pacote_droga || 0),
          blueprintPistola: Number(item.blueprint_pistola || 0),
          blueprintSmg: Number(item.blueprint_smg || 0),
          blueprintRifle: Number(item.blueprint_rifle || 0),
          pecasBasicas: Number(item.pecas_basicas || 0),
          pecasAvancadas: Number(item.pecas_avancadas || 0)
        }
      };
    });
  }

  renderCalcArmas();
</script>

<%- include('partials/footer') %>
