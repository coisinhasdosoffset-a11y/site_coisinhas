    <div class="barragem-right">
      <div class="calc-panel glass">
        <div class="calc-head">
          <span class="hub-small-badge">Calculadora</span>
          <h2>Resumo da Barragem</h2>
          <p class="section-subtext" style="text-align:left; max-width:none;">
            Adiciona os itens na esquerda e ajusta as quantidades aqui.
          </p>
        </div>

        <div class="calc-items" id="calcItems">
          <div class="empty-calc">
            <span class="empty-dot"></span>
            Ainda não tens itens adicionados.
          </div>
        </div>

        <div class="calc-summary">
          <div class="summary-row">
            <span>Total bruto</span>
            <strong id="grossTotal">0€</strong>
          </div>

          <div class="percent-box">
            <label for="percentInput">Percentagem a retirar</label>
            <div class="percent-input-wrap">
              <input id="percentInput" type="number" min="0" max="100" value="0" />
              <span>%</span>
            </div>
          </div>

          <div class="summary-row final-row">
            <span>Total final</span>
            <strong id="finalTotal">0€</strong>
          </div>

          <div class="calc-actions">
            <button type="button" class="btn btn-primary" id="saveBarragemBtn">Guardar</button>
            <button type="button" class="btn btn-secondary" id="clearBarragemBtn">Limpar</button>
          </div>

          <div class="save-message" id="saveMessage"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const barragemItems = {};
  const calcItems = document.getElementById('calcItems');
  const grossTotal = document.getElementById('grossTotal');
  const finalTotal = document.getElementById('finalTotal');
  const percentInput = document.getElementById('percentInput');
  const clearBarragemBtn = document.getElementById('clearBarragemBtn');
  const barragemFilter = document.getElementById('barragemFilter');

  const formatMoney = (value) => {
    return new Intl.NumberFormat('pt-PT').format(value) + '€';
  };

  function updateBarragemTotals() {
    let gross = 0;

    Object.values(barragemItems).forEach(item => {
      gross += item.price * item.qty;
    });

    const percent = Number(percentInput?.value || 0);
    const final = gross - (gross * percent / 100);

    grossTotal.textContent = formatMoney(gross);
    finalTotal.textContent = formatMoney(final);
  }

  function renderBarragemItems() {
    calcItems.innerHTML = '';

    const items = Object.values(barragemItems);

    if (!items.length) {
      calcItems.innerHTML = `
        <div class="empty-calc">
          <span class="empty-dot"></span>
          Ainda não tens itens adicionados.
        </div>
      `;
      updateBarragemTotals();
      return;
    }

    items.forEach(item => {
      const row = document.createElement('div');
      row.className = 'calc-item';
      row.innerHTML = `
        <div class="calc-item-top">
          <div>
            <h3>${item.name}</h3>
            <p>${item.type} • ${formatMoney(item.price)}</p>
          </div>
          <strong class="calc-item-total">${formatMoney(item.price * item.qty)}</strong>
        </div>

        <div class="calc-item-controls">
          <input type="number" min="1" value="${item.qty}" data-name="${item.name}" class="qty-input">
          <button type="button" class="remove-btn" data-name="${item.name}">Remover</button>
        </div>
      `;

      calcItems.appendChild(row);
    });

    updateBarragemTotals();
  }

  document.querySelectorAll('.add-item-btn').forEach(button => {
    button.addEventListener('click', () => {
      const card = button.closest('.loot-card');

      const name = card.dataset.name;
      const type = card.dataset.type;
      const price = Number(card.dataset.price);

      if (!barragemItems[name]) {
        barragemItems[name] = {
          name,
          type,
          price,
          qty: 1
        };
      } else {
        barragemItems[name].qty += 1;
      }

      renderBarragemItems();
    });
  });

  calcItems.addEventListener('input', (e) => {
    if (!e.target.classList.contains('qty-input')) return;

    const name = e.target.dataset.name;
    const qty = Math.max(1, Number(e.target.value || 1));

    barragemItems[name].qty = qty;
    renderBarragemItems();
  });

  calcItems.addEventListener('click', (e) => {
    if (!e.target.classList.contains('remove-btn')) return;

    const name = e.target.dataset.name;
    delete barragemItems[name];

    renderBarragemItems();
  });

  percentInput?.addEventListener('input', updateBarragemTotals);

  clearBarragemBtn?.addEventListener('click', () => {
    Object.keys(barragemItems).forEach(key => delete barragemItems[key]);
    percentInput.value = 0;
    renderBarragemItems();
  });

  barragemFilter?.addEventListener('change', () => {
    const selected = barragemFilter.value;

    document.querySelectorAll('.loot-card').forEach(card => {
      const type = card.dataset.type || '';

      if (selected === 'Todos' || type.includes(selected)) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  });
</script>

