    <div class="barragem-right">
      <div class="calc-panel glass">
        <div class="calc-head">
          <span class="hub-small-badge">Calculadora</span>
          <h2>Resumo da Barragem</h2>
          <p class="section-subtext" style="text-align:left; max-width:none;">
            Adiciona os itens na esquerda e ajusta as quantidades aqui.
          </p>
        </div>

        <div class="calc-items" id="calcItems">
          <div class="empty-calc">
            <span class="empty-dot"></span>
            Ainda não tens itens adicionados.
          </div>
        </div>

        <div class="calc-summary">
          <div class="summary-row">
            <span>Total bruto</span>
            <strong id="grossTotal">0€</strong>
          </div>

          <div class="percent-box">
            <label for="percentInput">Percentagem a retirar</label>
            <div class="percent-input-wrap">
              <input id="percentInput" type="number" min="0" max="100" value="0" />
              <span>%</span>
            </div>
          </div>

          <div class="summary-row final-row">
            <span>Total final</span>
            <strong id="finalTotal">0€</strong>
          </div>

          <div class="calc-actions">
            <button type="button" class="btn btn-primary" id="saveBarragemBtn">Guardar</button>
            <button type="button" class="btn btn-secondary" id="clearBarragemBtn">Limpar</button>
          </div>

          <div class="save-message" id="saveMessage"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  window.CURRENT_MODULE = 'barragem';
  window.BARRAGEM_CALCULOS = <%- JSON.stringify(calculos || []) %>;

  document.addEventListener('DOMContentLoaded', () => {
    const items = {};
    const calcItems = document.getElementById('calcItems');
    const grossTotal = document.getElementById('grossTotal');
    const finalTotal = document.getElementById('finalTotal');
    const percentInput = document.getElementById('percentInput');
    const saveBtn = document.getElementById('saveBarragemBtn');
    const clearBtn = document.getElementById('clearBarragemBtn');
    const saveMessage = document.getElementById('saveMessage');
    const filter = document.getElementById('barragemFilter');

    const formatMoney = value => new Intl.NumberFormat('pt-PT').format(Number(value || 0)) + '€';

    function findItemTypeByName(name) {
      const card = document.querySelector(`.loot-card[data-name="${CSS.escape(name)}"]`);
      return card ? card.dataset.type : 'Guardado';
    }

    function updateTotals() {
      let gross = 0;

      Object.values(items).forEach(item => {
        gross += Number(item.price || 0) * Number(item.qty || 0);

        const totalEl = document.querySelector(`[data-total-for="${CSS.escape(item.name)}"]`);
        if (totalEl) {
          totalEl.textContent = formatMoney(Number(item.price || 0) * Number(item.qty || 0));
        }
      });

      const percent = Number(percentInput.value || 0);
      const final = gross - (gross * percent / 100);

      grossTotal.textContent = formatMoney(gross);
      finalTotal.textContent = formatMoney(final);
    }

    function renderItems() {
      const values = Object.values(items);

      if (!values.length) {
        calcItems.innerHTML = `
          <div class="empty-calc">
            <span class="empty-dot"></span>
            Ainda não tens itens adicionados.
          </div>
        `;
        updateTotals();
        return;
      }

      calcItems.innerHTML = values.map(item => `
        <div class="calc-item" data-calc-item="${item.name}">
          <div class="calc-item-top">
            <div>
              <h3>${item.name}</h3>
              <p>${item.type} • ${formatMoney(item.price)}</p>
            </div>
            <strong class="calc-item-total" data-total-for="${item.name}">
              ${formatMoney(Number(item.price || 0) * Number(item.qty || 0))}
            </strong>
          </div>

          <div class="calc-item-controls">
            <input class="qty-input" type="number" min="1" value="${item.qty}" data-name="${item.name}">
            <button type="button" class="remove-btn" data-name="${item.name}">Remover</button>
          </div>
        </div>
      `).join('');

      updateTotals();
    }

    const savedItems = window.BARRAGEM_CALCULOS || [];

    if (Array.isArray(savedItems) && savedItems.length > 0) {
      savedItems.forEach(item => {
        items[item.nome_item] = {
          name: item.nome_item,
          type: findItemTypeByName(item.nome_item),
          price: Number(item.valor_unitario || 0),
          qty: Number(item.quantidade || 1)
        };
      });

      percentInput.value = Number(savedItems[0].percentagem || 0);
      renderItems();
    }

    document.addEventListener('click', e => {
      const addBtn = e.target.closest('.add-item-btn');

      if (addBtn) {
        const card = addBtn.closest('.loot-card');
        const name = card.dataset.name;

        if (!items[name]) {
          items[name] = {
            name,
            type: card.dataset.type,
            price: Number(card.dataset.price),
            qty: 1
          };

          renderItems();
        } else {
          items[name].qty += 1;

          const input = document.querySelector(`.qty-input[data-name="${CSS.escape(name)}"]`);
          if (input) input.value = items[name].qty;

          updateTotals();
        }

        saveMessage.textContent = '';
      }

      const removeBtn = e.target.closest('.remove-btn');

      if (removeBtn) {
        delete items[removeBtn.dataset.name];
        renderItems();
        saveMessage.textContent = '';
      }
    });

    calcItems.addEventListener('input', e => {
      if (!e.target.classList.contains('qty-input')) return;

      const name = e.target.dataset.name;
      const value = Number(e.target.value || 1);

      items[name].qty = Math.max(1, value);
      updateTotals();
      saveMessage.textContent = '';
    });

    percentInput.addEventListener('input', () => {
      updateTotals();
      saveMessage.textContent = '';
    });

    saveBtn.addEventListener('click', async () => {
      const payload = {
        percentagem: Number(percentInput.value || 0),
        items: Object.values(items).map(item => ({
          nome: item.name,
          valor: Number(item.price || 0),
          quantidade: Number(item.qty || 0)
        }))
      };

      if (!payload.items.length) {
        saveMessage.textContent = 'Adiciona pelo menos um item antes de guardar.';
        return;
      }

      saveMessage.textContent = 'A guardar...';

      try {
        const res = await fetch('/barragem/save', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        const data = await res.json();

        if (!res.ok || !data.success) {
          throw new Error(data.message || 'Erro ao guardar.');
        }

        saveMessage.textContent = 'Guardado com sucesso.';
      } catch (err) {
        console.error(err);
        saveMessage.textContent = 'Erro ao guardar.';
      }
    });

    clearBtn.addEventListener('click', async () => {
      Object.keys(items).forEach(key => delete items[key]);
      percentInput.value = 0;
      renderItems();

      try {
        await fetch('/barragem/clear', { method: 'POST' });
        saveMessage.textContent = 'Limpo com sucesso.';
      } catch (err) {
        console.error(err);
        saveMessage.textContent = 'Erro ao limpar.';
      }
    });

    if (filter) {
      filter.addEventListener('change', () => {
        const selected = filter.value;

        document.querySelectorAll('.loot-card').forEach(card => {
          const type = card.dataset.type || '';
          card.style.display =
            selected === 'Todos' || type.includes(selected)
              ? ''
              : 'none';
        });
      });
    }
  });
</script>

<%- include('partials/footer') %>
