          <p class="section-subtext" style="text-align:left; max-width:none;">
            Adiciona os itens na esquerda e ajusta as quantidades aqui.
          </p>
        </div>

        <div class="calc-items" id="calcItems">
          <div class="empty-calc">
            <span class="empty-dot"></span>
            Ainda não tens itens adicionados.
          </div>
        </div>

        <div class="calc-summary">
          <div class="summary-row">
            <span>Total bruto</span>
            <strong id="grossTotal">0€</strong>
          </div>

          <div class="percent-box">
            <label for="percentInput">Percentagem a retirar</label>
            <div class="percent-input-wrap">
              <input id="percentInput" type="number" min="0" max="100" value="0" />
              <span>%</span>
            </div>
          </div>

          <div class="summary-row final-row">
            <span>Total final</span>
            <strong id="finalTotal">0€</strong>
          </div>

          <div class="calc-actions">
            <button type="button" class="btn btn-primary" id="saveBarragemBtn">Guardar</button>
            <button type="button" class="btn btn-secondary" id="clearBarragemBtn">Limpar</button>
          </div>

          <div class="save-message" id="saveMessage"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  window.CURRENT_MODULE = 'barragem';
  window.BARRAGEM_CALCULOS = <%- JSON.stringify(calculos || []) %>;

  document.addEventListener('DOMContentLoaded', () => {
    const items = {};
    const calcItems = document.getElementById('calcItems');
    const grossTotal = document.getElementById('grossTotal');
    const finalTotal = document.getElementById('finalTotal');
    const percentInput = document.getElementById('percentInput');
    const clearBtn = document.getElementById('clearBarragemBtn');
    const saveBtn = document.getElementById('saveBarragemBtn');
    const saveMessage = document.getElementById('saveMessage');
    const filter = document.getElementById('barragemFilter');

    const formatMoney = (value) => new Intl.NumberFormat('pt-PT').format(Number(value || 0)) + '€';

    function escapeHtml(value) {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function getTotals() {
      const gross = Object.values(items).reduce((sum, item) => sum + item.price * item.qty, 0);
      const percent = Math.min(100, Math.max(0, Number(percentInput.value || 0)));
      const final = gross - (gross * percent / 100);
      return { gross, percent, final };
    }

    function updateTotals() {
      Object.values(items).forEach((item) => {
        const totalEl = calcItems.querySelector(`[data-total-for="${CSS.escape(item.name)}"]`);
        if (totalEl) totalEl.textContent = formatMoney(item.price * item.qty);
      });

      const totals = getTotals();
      grossTotal.textContent = formatMoney(totals.gross);
      finalTotal.textContent = formatMoney(totals.final);
    }

    function renderItems() {
      const values = Object.values(items);

      if (!values.length) {
        calcItems.innerHTML = `
          <div class="empty-calc">
            <span class="empty-dot"></span>
            Ainda não tens itens adicionados.
          </div>
        `;
        updateTotals();
        return;
      }

      calcItems.innerHTML = values.map((item) => `
        <div class="calc-item" data-calc-item="${escapeHtml(item.name)}">
          <div class="calc-item-top">
            <div>
              <h3>${escapeHtml(item.name)}</h3>
              <p>${escapeHtml(item.type)} • ${formatMoney(item.price)}</p>
            </div>
            <strong class="calc-item-total" data-total-for="${escapeHtml(item.name)}">
              ${formatMoney(item.price * item.qty)}
            </strong>
          </div>

          <div class="calc-item-controls">
            <input class="qty-input" type="number" min="1" value="${item.qty}" data-name="${escapeHtml(item.name)}" />
            <button type="button" class="remove-btn" data-name="${escapeHtml(item.name)}">Remover</button>
          </div>
        </div>
      `).join('');

      updateTotals();
    }

    document.addEventListener('click', (event) => {
      const addBtn = event.target.closest('.add-item-btn');
      if (addBtn) {
        const card = addBtn.closest('.loot-card');
        const name = card.dataset.name;
        const type = card.dataset.type;
        const price = Number(card.dataset.price || 0);

        if (!items[name]) {
          items[name] = { name, type, price, qty: 1 };
          renderItems();
        } else {
          items[name].qty += 1;
          const input = calcItems.querySelector(`.qty-input[data-name="${CSS.escape(name)}"]`);
          if (input) input.value = items[name].qty;
          updateTotals();
        }
      }

      const removeBtn = event.target.closest('.remove-btn');
      if (removeBtn) {
        delete items[removeBtn.dataset.name];
        renderItems();
      }
    });

    calcItems.addEventListener('input', (event) => {
      if (!event.target.classList.contains('qty-input')) return;

      const name = event.target.dataset.name;
      if (!items[name]) return;

      const rawValue = event.target.value;
      const qty = rawValue === '' ? 0 : Number(rawValue);
      items[name].qty = Math.max(0, qty);
      updateTotals();
    });

    calcItems.addEventListener('blur', (event) => {
      if (!event.target.classList.contains('qty-input')) return;

      const name = event.target.dataset.name;
      if (!items[name]) return;

      if (!event.target.value || Number(event.target.value) < 1) {
        event.target.value = 1;
        items[name].qty = 1;
        updateTotals();
      }
    }, true);

    percentInput.addEventListener('input', updateTotals);

    clearBtn.addEventListener('click', () => {
      Object.keys(items).forEach((key) => delete items[key]);
      percentInput.value = 0;
      renderItems();
      saveMessage.textContent = '';
    });

    saveBtn.addEventListener('click', async () => {
      const totals = getTotals();
      const payload = {
        modulo: 'barragem',
        items: Object.values(items),
        percentagem: totals.percent,
        totalBruto: totals.gross,
        totalFinal: totals.final
      };

      if (!payload.items.length) {
        saveMessage.textContent = 'Adiciona pelo menos um item antes de guardar.';
        return;
      }

      saveMessage.textContent = 'A guardar...';

      try {
        const response = await fetch('/barragem/guardar', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!response.ok) throw new Error('Erro ao guardar');

        saveMessage.textContent = 'Guardado com sucesso.';
      } catch (error) {
        localStorage.setItem('barragem_ultimo_calculo', JSON.stringify(payload));
        saveMessage.textContent = 'Guardado localmente. Falta confirmar a rota POST /barragem/guardar no backend.';
      }
    });

    filter.addEventListener('change', () => {
      const selected = filter.value;

      document.querySelectorAll('.loot-card').forEach((card) => {
        const type = card.dataset.type || '';
        card.style.display = selected === 'Todos' || type.includes(selected) ? '' : 'none';
      });
    });
  });
</script>

