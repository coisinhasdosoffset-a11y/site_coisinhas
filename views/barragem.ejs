    <div class="barragem-right">
      <div class="calc-panel glass">
        <div class="calc-head">
          <span class="hub-small-badge">Calculadora</span>
          <h2>Resumo da Barragem</h2>
          <p class="section-subtext" style="text-align:left; max-width:none;">
            Adiciona os itens na esquerda e ajusta as quantidades aqui.
          </p>
        </div>

        <div class="calc-items" id="calcItems">
          <div class="empty-calc">
            <span class="empty-dot"></span>
            Ainda não tens itens adicionados.
          </div>
        </div>

        <div class="calc-summary">
          <div class="summary-row">
            <span>Total bruto</span>
            <strong id="grossTotal">0€</strong>
          </div>

          <div class="percent-box">
            <label for="percentInput">Percentagem a retirar</label>
            <div class="percent-input-wrap">
              <input id="percentInput" type="number" min="0" max="100" value="0" />
              <span>%</span>
            </div>
          </div>

          <div class="summary-row final-row">
            <span>Total final</span>
            <strong id="finalTotal">0€</strong>
          </div>

          <div class="calc-actions">
            <button type="button" class="btn btn-primary" id="saveBarragemBtn">Guardar</button>
            <button type="button" class="btn btn-secondary" id="clearBarragemBtn">Limpar</button>
          </div>

          <div class="save-message" id="saveMessage"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  window.CURRENT_MODULE = 'barragem';
  window.BARRAGEM_CALCULOS = <%- JSON.stringify(calculos || []) %>;
</script>

<%- include('partials/footer') %>
