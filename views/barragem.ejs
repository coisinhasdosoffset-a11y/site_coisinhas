<%- include('partials/header', { page: 'barragem' }) %>

<section class="barragem-shell">

  <!-- HEADER -->
  <div class="barragem-header glass">
    <div>
      <span class="barragem-tag">Módulo • Barragem</span>
      <h1>Barragem</h1>
      <p class="barragem-subtitle">
        Adiciona itens, escolhe quantidades, aplica percentagem e guarda tudo automaticamente.
      </p>
    </div>

    <!-- FILTRO -->
    <div class="filter-box barragem-header-filter">
      <label for="barragemFilter">Filtrar por</label>
      <select id="barragemFilter">
        <option value="Todos">Todos</option>
        <option value="Contentores">Contentores</option>
        <option value="Casas">Casas</option>
        <option value="Carrinhas">Carrinhas</option>
      </select>
    </div>
  </div>

  <!-- GRID -->
  <div class="barragem-grid">

    <!-- ESQUERDA -->
    <div class="barragem-left">
      <div class="loot-list">

        <!-- ITEM -->
        <div class="loot-card glass" data-name="Perfume" data-type="Contentores" data-price="300">
          <div class="loot-info">
            <span class="loot-type">Contentores</span>
            <h3>Perfume</h3>
            <p>Item da barragem para venda.</p>
          </div>
          <div class="loot-actions">
            <strong>300€</strong>
            <button class="add-item-btn">Adicionar</button>
          </div>
        </div>

        <div class="loot-card glass" data-name="Pack de Vinho" data-type="Contentores" data-price="600">
          <div class="loot-info">
            <span class="loot-type">Contentores</span>
            <h3>Pack de Vinho</h3>
          </div>
          <div class="loot-actions">
            <strong>600€</strong>
            <button class="add-item-btn">Adicionar</button>
          </div>
        </div>

        <div class="loot-card glass" data-name="Phone 7" data-type="Contentores" data-price="960">
          <div class="loot-info">
            <span class="loot-type">Contentores</span>
            <h3>Phone 7</h3>
          </div>
          <div class="loot-actions">
            <strong>960€</strong>
            <button class="add-item-btn">Adicionar</button>
          </div>
        </div>

        <div class="loot-card glass" data-name="Computador" data-type="Casas" data-price="1200">
          <div class="loot-info">
            <span class="loot-type">Casas</span>
            <h3>Computador</h3>
          </div>
          <div class="loot-actions">
            <strong>1.200€</strong>
            <button class="add-item-btn">Adicionar</button>
          </div>
        </div>

      </div>
    </div>

    <!-- DIREITA -->
    <div class="barragem-right">
      <div class="calc-panel glass">

        <h2>Resumo da Barragem</h2>

        <div id="calcItems" class="calc-items">
          <div class="empty-calc">
            <span class="empty-dot"></span>
            Ainda não tens itens adicionados.
          </div>
        </div>

        <div class="calc-summary">
          <div class="summary-row">
            <span>Total bruto</span>
            <strong id="grossTotal">0€</strong>
          </div>

          <div class="percent-box">
            <label>Percentagem a retirar</label>
            <input id="percentInput" type="number" value="0">
          </div>

          <div class="summary-row">
            <span>Total final</span>
            <strong id="finalTotal">0€</strong>
          </div>

          <div class="calc-actions">
            <button id="clearBarragemBtn" class="btn btn-secondary">Limpar</button>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<!-- SCRIPT -->
<script>
  window.CURRENT_MODULE = 'barragem';
  window.BARRAGEM_CALCULOS = <%- JSON.stringify(calculos || []) %>;

  document.addEventListener('DOMContentLoaded', () => {
    const items = {};
    const calcItems = document.getElementById('calcItems');
    const grossTotal = document.getElementById('grossTotal');
    const finalTotal = document.getElementById('finalTotal');
    const percentInput = document.getElementById('percentInput');
    const clearBtn = document.getElementById('clearBarragemBtn');
    const saveBtn = document.getElementById('saveBarragemBtn');
    const saveMessage = document.getElementById('saveMessage');
    const filter = document.getElementById('barragemFilter');

    const formatMoney = value => new Intl.NumberFormat('pt-PT').format(value) + '€';

    function updateTotals() {
      let gross = 0;

      Object.values(items).forEach(item => {
        gross += item.price * item.qty;
        const totalEl = document.querySelector(`[data-total-for="${CSS.escape(item.name)}"]`);
        if (totalEl) totalEl.textContent = formatMoney(item.price * item.qty);
      });

      const percent = Number(percentInput.value || 0);
      const final = gross - (gross * percent / 100);

      grossTotal.textContent = formatMoney(gross);
      finalTotal.textContent = formatMoney(final);
    }

    function renderItems() {
      const values = Object.values(items);

      if (!values.length) {
        calcItems.innerHTML = `
          <div class="empty-calc">
            <span class="empty-dot"></span>
            Ainda não tens itens adicionados.
          </div>
        `;
        updateTotals();
        return;
      }

      calcItems.innerHTML = values.map(item => `
        <div class="calc-item" data-calc-item="${item.name}">
          <div class="calc-item-top">
            <div>
              <h3>${item.name}</h3>
              <p>${item.type} • ${formatMoney(item.price)}</p>
            </div>
            <strong class="calc-item-total" data-total-for="${item.name}">
              ${formatMoney(item.price * item.qty)}
            </strong>
          </div>

          <div class="calc-item-controls">
            <input class="qty-input" type="number" min="1" value="${item.qty}" data-name="${item.name}">
            <button type="button" class="remove-btn" data-name="${item.name}">Remover</button>
          </div>
        </div>
      `).join('');

      updateTotals();
    }

    document.addEventListener('click', e => {
      const addBtn = e.target.closest('.add-item-btn');

      if (addBtn) {
        const card = addBtn.closest('.loot-card');
        const name = card.dataset.name;

        if (!items[name]) {
          items[name] = {
            name,
            type: card.dataset.type,
            price: Number(card.dataset.price),
            qty: 1
          };
          renderItems();
        } else {
          items[name].qty += 1;

          const input = document.querySelector(`.qty-input[data-name="${CSS.escape(name)}"]`);
          if (input) input.value = items[name].qty;

          updateTotals();
        }
      }

      const removeBtn = e.target.closest('.remove-btn');

      if (removeBtn) {
        delete items[removeBtn.dataset.name];
        renderItems();
      }
    });

    calcItems.addEventListener('input', e => {
      if (!e.target.classList.contains('qty-input')) return;

      const name = e.target.dataset.name;
      items[name].qty = Math.max(1, Number(e.target.value || 1));

      updateTotals();
    });

    percentInput.addEventListener('input', updateTotals);

    clearBtn.addEventListener('click', () => {
      Object.keys(items).forEach(key => delete items[key]);
      percentInput.value = 0;
      renderItems();
    });

    saveBtn.addEventListener('click', async () => {
      const payload = {
        modulo: 'barragem',
        items: Object.values(items),
        percentagem: Number(percentInput.value || 0),
        totalBruto: Number(grossTotal.textContent.replace(/\D/g, '') || 0),
        totalFinal: Number(finalTotal.textContent.replace(/\D/g, '') || 0)
      };

      saveMessage.textContent = 'A guardar...';

      try {
        const res = await fetch('/barragem/guardar', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!res.ok) throw new Error();

        saveMessage.textContent = 'Guardado com sucesso.';
      } catch {
        saveMessage.textContent = 'Erro ao guardar. Confirma se existe a rota POST /barragem/guardar.';
      }
    });

    if (filter) {
      filter.addEventListener('change', () => {
        const selected = filter.value;

        document.querySelectorAll('.loot-card').forEach(card => {
          const type = card.dataset.type || '';
          card.style.display = selected === 'Todos' || type.includes(selected) ? '' : 'none';
        });
      });
    }
  });
</script>
<%- include('partials/footer') %>
